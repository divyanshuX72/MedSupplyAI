# Production Environment Variables (Render/Heroku/Railway)

# 1. Database Connection
# Most cloud providers give you a 'Internal Database URL' or 'External Database URL'.
# Paste that entire string here.
DATABASE_URL=postgresql://user:password@hostname:port/database_name?sslmode=require

# 2. Server Configuration
# Render sets PORT automatically, but you can set a default for local testing
PORT=3001

# 3. Legacy Connection (If not using DATABASE_URL)
# DB_HOST=your-db-host
# DB_USER=your-db-user
# DB_PASSWORD=your-db-pass
# DB_NAME=your-db-name
# DB_PORT=5432
